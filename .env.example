# Copy to `.env` and fill in. Loaded by src/distill_audit/judge/*.
# The repo points at this file automatically (walks up from CWD); override with
#   export DISTILL_AUDIT_ENV=/abs/path/to/.env
# NEVER commit the real .env — it is gitignored.

# --- Kimi (two keys rotated for rate-limit headroom) ---
KIMI_API_KEY1=
KIMI_API_KEY2=
KIMI_MODEL=kimi-for-coding

# --- DeepSeek-V4-Flash via OpenCode gateway ---
OpenCode-URL=
OpenCode-APIKEY=
OpenCode-model=

# --- MiniMax-M3 ---
MINIMAX_API_KEY=

# --- (optional) primary judge: Anthropic / local proxy ---
# KIMI_BASE_URL=http://localhost:4242
